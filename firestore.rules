rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "dZS7jUaB43aCL5Km3zr5V4LZuMr1";
    }

    function nonEmptyString(v) {
      return v is string && v.size() > 0;
    }

    function nonNegativeNumber(v) {
      return v is number && v >= 0;
    }

    function validOptionalString(v) {
      return v == null || v is string;
    }

    function validProduct(data) {
      return nonEmptyString(data.name)
        && nonEmptyString(data.model)
        && nonEmptyString(data.seriesQtyText)
        && nonNegativeNumber(data.pricePiece)
        && nonNegativeNumber(data.priceWholesale)
        && (data.discountPercent == null || (data.discountPercent is number && data.discountPercent >= 0 && data.discountPercent < 100))
        && (data.imageUrls == null || data.imageUrls is list)
        && (data.visible == null || data.visible is bool)
        && (data.pinned == null || data.pinned is bool)
        && validOptionalString(data.season)
        && validOptionalString(data.sizes)
        && validOptionalString(data.badgeText)
        && validOptionalString(data.description)
        && validOptionalString(data.codeCategory);
    }

    function validCategory(data) {
      return (data.label == null || data.label is string)
        && (data.type == null || data.type in ['code', 'season'])
        && validOptionalString(data.code)
        && validOptionalString(data.season);
    }

    function validOrder(data) {
      return nonEmptyString(data.customerName)
        && nonEmptyString(data.customerPhone)
        && nonEmptyString(data.city)
        && nonEmptyString(data.address)
        && nonNegativeNumber(data.total)
        && data.items is list
        && data.items.size() > 0
        && validOptionalString(data.paymentMethod)
        && validOptionalString(data.shippingMethod)
        && validOptionalString(data.notes)
        && validOptionalString(data.status);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && validProduct(request.resource.data);
      allow update: if isAdmin() && validProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if validOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /company/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /shipping/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
